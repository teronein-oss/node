rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Registration requests — users can read/write their own
    match /registrations/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Admin can read/write all registrations
      allow read, write: if request.auth != null
        && request.auth.token.email == 'teronein@gmail.com';
    }

    // User profile metadata (set by admin on approval)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read, write: if request.auth != null
        && request.auth.token.email == 'teronein@gmail.com';
    }

    // Shared config (admin UID for 조교 access)
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.email == 'teronein@gmail.com';
    }

    // App state per user (grades, homework, schedule, etc.)
    match /appData/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Admin can read/write any user's data (for viewing mode)
      allow read, write: if request.auth != null
        && request.auth.token.email == 'teronein@gmail.com';
      // 조교 can read/write assigned teacher's data
      allow read, write: if request.auth != null
        && get(/databases/$(database)/documents/registrations/$(request.auth.uid)).data.role == '조교'
        && get(/databases/$(database)/documents/registrations/$(request.auth.uid)).data.status == 'approved'
        && get(/databases/$(database)/documents/registrations/$(request.auth.uid)).data.assignedTeacherUid == userId;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return signedIn() && request.auth.token.email == 'teronein@gmail.com';
    }

    function regPath(uid) {
      return /databases/$(database)/documents/registrations/$(uid);
    }

    function hasRegistration(uid) {
      return exists(regPath(uid));
    }

    function myRegistration() {
      return get(regPath(request.auth.uid)).data;
    }

    function myAcademyId() {
      return hasRegistration(request.auth.uid) && ('academyId' in myRegistration())
        ? myRegistration().academyId
        : 'node-default';
    }

    function isApproved() {
      return signedIn()
        && hasRegistration(request.auth.uid)
        && myRegistration().status == 'approved';
    }

    function isAcademyMember(academyId) {
      return isSuperAdmin() || (isApproved() && myAcademyId() == academyId);
    }

    function isAcademyAdmin(academyId) {
      return isSuperAdmin()
        || (
          isApproved()
          && myAcademyId() == academyId
          && (myRegistration().role == '관리자' || myRegistration().role == '원장')
        );
    }

    function isDefaultMember() {
      return isSuperAdmin() || (isApproved() && myAcademyId() == 'node-default');
    }

    function isAssignedJogyo(userId) {
      return isApproved()
        && myRegistration().role == '조교'
        && (
          myRegistration().assignedTeacherUid == userId
          || (
            'assignedTeacherUids' in myRegistration()
            && userId in myRegistration().assignedTeacherUids
          )
        );
    }

    match /academies/{academyId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isAcademyAdmin(academyId);

      match /config/{docId} {
        allow read: if isAcademyMember(academyId);
        allow write: if isAcademyAdmin(academyId);
      }

      match /appData/{userId} {
        allow read, write: if isSuperAdmin()
          || (isAcademyMember(academyId) && request.auth.uid == userId)
          || isAcademyAdmin(academyId)
          || (isAcademyMember(academyId) && isAssignedJogyo(userId));
      }

      match /users/{userId} {
        allow read, write: if isSuperAdmin()
          || (isAcademyMember(academyId) && request.auth.uid == userId)
          || isAcademyAdmin(academyId);
      }

      match /sharedStudentRosters/{userId} {
        allow read: if isAcademyMember(academyId);
        allow write: if isSuperAdmin()
          || (isAcademyMember(academyId) && request.auth.uid == userId)
          || isAcademyAdmin(academyId)
          || (isAcademyMember(academyId) && isAssignedJogyo(userId));
      }

      match /studentDashboardRows/{rowId} {
        allow read, write: if isAcademyMember(academyId);
      }
    }

    match /registrations/{userId} {
      allow create: if signedIn() && request.auth.uid == userId;
      allow read, write: if signedIn() && request.auth.uid == userId;
      allow read, write: if isSuperAdmin();
      allow read, update, delete: if signedIn()
        && resource.data.academyId == myAcademyId()
        && isAcademyAdmin(resource.data.academyId);
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
      allow read, write: if isSuperAdmin();
      allow read, write: if isDefaultMember() && (myRegistration().role == '관리자' || myRegistration().role == '원장');
    }

    match /config/{docId} {
      allow read: if isDefaultMember();
      allow write: if isSuperAdmin() || (isDefaultMember() && (myRegistration().role == '관리자' || myRegistration().role == '원장'));
    }

    match /appData/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
      allow read, write: if isSuperAdmin();
      allow read, write: if isDefaultMember() && (myRegistration().role == '관리자' || myRegistration().role == '원장');
      allow read, write: if isDefaultMember() && isAssignedJogyo(userId);
      allow read: if isDefaultMember()
        && get(/databases/$(database)/documents/config/sharedData).data.adminUid == userId;
    }

    match /sharedStudentRosters/{userId} {
      allow read: if isDefaultMember();
      allow write: if isSuperAdmin()
        || (signedIn() && request.auth.uid == userId)
        || (isDefaultMember() && (myRegistration().role == '관리자' || myRegistration().role == '원장'))
        || (isDefaultMember() && isAssignedJogyo(userId));
    }

    match /studentDashboardRows/{rowId} {
      allow read, write: if isDefaultMember();
    }
  }
}
